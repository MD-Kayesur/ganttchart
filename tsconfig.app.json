{
  "compilerOptions": {
    "jsx": "react",  // React JSX support
    "module": "esnext",  // Latest module system for ES
    "target": "esnext",  // Latest ECMAScript version
    "strict": true,  // Enforce strict type-checking
    "esModuleInterop": true,  // Allow interoperability between CommonJS and ES Modules
    "skipLibCheck": true  // Skip checking of library files
  },
  "include": [
    "src/**/*.ts",  // Includes all TypeScript files in the src folder
    "src/**/*.tsx"  // Includes all TypeScript files with JSX in the src folder
  ]
}
